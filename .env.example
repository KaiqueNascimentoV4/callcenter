# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000
# URL pública HTTPS do servidor (sem barra no final)
PUBLIC_BASE_URL=https://api.suaempresa.com
# URL pública WSS do endpoint /media
WS_PUBLIC_URL=wss://api.suaempresa.com/media

# ── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+5511XXXXXXXXX

# ── Gemini ────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Modelo Live API disponível (verifique a documentação para o modelo mais recente)
GEMINI_MODEL=gemini-2.0-flash-live-001
# Voz do agente: Kore, Charon, Fenrir, Aoede, Puck, Leda, Orus, Zephyr
GEMINI_VOICE=Kore

# ── Banco de dados ────────────────────────────────────────────────────────────
# Caminho do SQLite (padrão: data.db na raiz do projeto)
DATABASE_PATH=./data.db

# ── Integrações ───────────────────────────────────────────────────────────────
# Webhook n8n disparado após salvar resultado de ligação (opcional)
N8N_WEBHOOK_URL=

# ── Empresa ───────────────────────────────────────────────────────────────────
EMPRESA_NOME=Minha Empresa

# ── Ambiente ──────────────────────────────────────────────────────────────────
# Em produção, define "production" para ativar validação de assinatura Twilio
NODE_ENV=development
